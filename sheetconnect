const scriptURL = "AKfycbxG2z4p1EbidGmLG1gUKOar4E7mJ-xBsSYCErGhbfY";

async function submitMenuRecommendation(menuName, reason) {
  const response = await fetch(scriptURL, {
    method: "POST",
    body: JSON.stringify({
      menuName,
      reason
    })
  });

  const result = await response.json();
  return result;
}
